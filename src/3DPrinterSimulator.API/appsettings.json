{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "PrinterFarm": "Information"
    }
  },
  "AllowedHosts": "*",
  "Simulation": {
    "TickIntervalMs": 5000,
    "AutoJobProbability": 0.20,
    "FilamentWarningThresholdGrams": 120.0
  },
  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "3dprinter"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "MaxRetryCount": 3,
    "RetryDelayMs": 30000
  }
}
